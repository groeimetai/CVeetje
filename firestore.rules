rules_version = '2';

// Firestore Security Rules voor CVeetje
//
// Principes:
// - Default deny: alles wat niet expliciet is toegestaan is geblokkeerd.
// - User-data scoping: gebruikers kunnen alleen hun eigen documenten lezen/schrijven.
// - Sensitive fields (credits, apiKey, role, disabled, ageConfirmed, email):
//   alleen via server-side API routes met Admin SDK — Admin SDK bypast rules.
// - Append-only logs: transacties + admin_audit_log zijn immutable (geen update/delete).
// - Admin-acties die persoonsgegevens raken worden gelogd via
//   src/lib/admin/audit-log.ts (AVG art. 32 lid 1 sub b/d).

service cloud.firestore {
  match /databases/{database}/documents {

    // ============ Helper Functions ============

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function fieldExists(field) {
      return field != null;
    }

    // ============ Users Collection ============
    // /users/{userId}
    //
    // Server-only velden (alleen via Admin SDK schrijfbaar):
    //   credits, apiKey, role, disabled, disabledReason, email,
    //   ageConfirmed, ageConfirmedAt, createdAt, lastLoginAt
    //
    // Client mag updaten: displayName, photoURL, updatedAt
    //
    // Creatie alleen via /api/auth/init-user (Admin SDK).

    match /users/{userId} {
      // Read: eigen doc of admin (voor impersonation / user-management)
      allow read: if isOwner(userId) || isAdmin();

      // Create: geblokkeerd voor clients — moet via Admin SDK (API /api/auth/init-user)
      // Dit voorkomt dat een gebruiker zelf een doc maakt en daarbij velden invult
      // die normaal alleen server-side worden gezet (credits, role, ageConfirmed).
      allow create: if false;

      // Update: alleen eigenaar, en alleen op een strikte whitelist van velden
      allow update: if isOwner(userId) && isValidUserUpdate();

      // Delete: alleen via /api/settings/account (Admin SDK)
      allow delete: if false;

      function isValidUserUpdate() {
        let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();

        // Strikte whitelist — alles wat hier niet in staat is server-only.
        // (Belangrijk: dit gebruikt hasOnly, niet hasAny, zodat een gebruiker
        // geen willekeurige nieuwe velden kan toevoegen zoals ageConfirmed.)
        let allowedFields = ['displayName', 'photoURL', 'updatedAt'];

        return affectedKeys.hasOnly(allowedFields);
      }

      // ============ Transactions Subcollection ============
      // /users/{userId}/transactions/{transactionId}
      // Append-only audit log voor credit-operaties (purchase, monthly_free,
      // cv_generation, etc.). Alleen Admin SDK schrijft, gebruiker leest.

      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update, delete: if false; // Admin SDK only
      }

      // ============ CVs Subcollection ============
      // /users/{userId}/cvs/{cvId}

      match /cvs/{cvId} {
        allow read: if isOwner(userId) || isAdmin();

        // Create: eigenaar mag, mits minimale velden aanwezig zijn.
        // Status moet op 'draft' beginnen (geen direct 'published' kunstgreep).
        allow create: if isOwner(userId) && validCVCreate();

        // Update: eigenaar — pdfUrl wordt server-side gezet maar
        // we leggen geen veld-restrictie op om de wizard niet te breken.
        allow update: if isOwner(userId);

        allow delete: if isOwner(userId);

        function validCVCreate() {
          let data = request.resource.data;
          return fieldExists(data.linkedInData)
            && fieldExists(data.template)
            && fieldExists(data.colorScheme)
            && fieldExists(data.status)
            && data.status == 'draft';
        }

        // ============ Disputes Subcollection ============
        // /users/{userId}/cvs/{cvId}/disputes/{disputeId}
        // Disputes flow gaat via /api/cv/[id]/dispute (Admin SDK) en
        // /api/admin/disputes/.../resolve. Clients schrijven nooit direct.

        match /disputes/{disputeId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create, update, delete: if false; // Admin SDK only
        }
      }

      // ============ Applications Subcollection ============
      // /users/{userId}/applications/{applicationId}
      //
      // Created via Admin SDK (server records ATS submission).
      // Users mogen status en notes updaten op hun eigen applications.

      match /applications/{applicationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if false; // Admin SDK only

        allow update: if isOwner(userId) && isValidApplicationUpdate();
        allow delete: if isOwner(userId);

        function isValidApplicationUpdate() {
          let affected = request.resource.data.diff(resource.data).affectedKeys();
          let allowed = ['status', 'notes', 'updatedAt'];
          return affected.hasOnly(allowed);
        }
      }

      // ============ Profiles Subcollection ============
      // /users/{userId}/profiles/{profileId}

      match /profiles/{profileId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && validProfileCreate();
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);

        function validProfileCreate() {
          let data = request.resource.data;
          return fieldExists(data.name) && fieldExists(data.parsedData);
        }
      }

      // ============ User Templates Subcollection ============
      // /users/{userId}/templates/{templateId}
      // Upload/CRUD via /api/templates (Admin SDK schrijft naar Firestore +
      // Storage). Clients lezen via API of via deze regel rechtstreeks.

      match /templates/{templateId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update, delete: if false; // Admin SDK only
      }
    }

    // ============ Global Templates Collection ============
    // /globalTemplates/{templateId}
    // Read: alle ingelogde users; Write: admin-only via Admin SDK.

    match /globalTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ============ Jobs Cache Collection ============
    // /jobs/{jobSlug}
    // Public read (jobs board is publiek toegankelijk). Server writes only.

    match /jobs/{jobSlug} {
      allow read: if true;
      allow write: if false;
    }

    // ============ Feedback Collection ============
    // /feedback/{feedbackId}
    // POST via /api/feedback (Admin SDK creëert + maakt GitHub issue).
    // Gebruiker mag eigen feedback lezen voor de UI; admin alles.

    match /feedback/{feedbackId} {
      allow read: if isAdmin() ||
                  (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if false; // Admin SDK only
    }

    // ============ Kanban Collections ============
    // /kanban_boards, /kanban_cards
    // Admin-only feature; alle reads en writes via /api/admin/kanban/...
    // routes (verifyAdminRequest + Admin SDK). Default-deny op rules
    // niveau voor extra zekerheid.

    match /kanban_boards/{boardId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /kanban_cards/{cardId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ============ Admin Audit Log ============
    // /admin_audit_log/{entryId}
    // AVG art. 32 — accountability trail. Read-only voor admins, immutable.

    match /admin_audit_log/{entryId} {
      allow read: if isAdmin();
      allow create, update, delete: if false; // Server-side only via Admin SDK
    }

    // ============ Mail Queue ============
    // /mail/{mailId}
    // Firebase Trigger Email extension leest hier transactionele e-mails.
    // Bevat e-mailadressen en inhoud van mails — gevoelig. Strikt server-only.

    match /mail/{mailId} {
      allow read: if false;
      allow write: if false;
    }

    // ============ Platform Config ============
    // /platformConfig/{docId}
    // Admin-managed configuratie (AI-modellen, credit-kosten). Server-side only.

    match /platformConfig/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ============ Default Deny ============
    // Belangrijk: deze match catches alle paden die hierboven niet zijn
    // gedefinieerd. Voorkomt onbedoelde toegang bij nieuwe collecties.

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
